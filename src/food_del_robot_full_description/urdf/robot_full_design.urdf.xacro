<?xml version="1.0"?>
<robot name="robot_full_design"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="use_sim"   default="false"/>
  <xacro:arg name="use_lidar" default="true"/>

  <!-- ============================================================
       Properties
       ============================================================ -->

  <!-- Base body — SW mass; heavy parts (motors, batteries, chassis) sit low -->
  <xacro:property name="base_mass"   value="17.12"/>
  <xacro:property name="base_len"    value="0.42"/>
  <xacro:property name="base_width"  value="0.42"/>
  <xacro:property name="base_height" value="0.64"/>
  <xacro:property name="base_com_z"  value="0.08"/>  <!-- lowered CoM: heavy parts near base -->

  <!-- Wheels — old URDF values; SW wheel mass (21.77 kg) is corrupt due to grouping error -->
  <xacro:property name="wheel_mass"       value="5.5"/>
  <xacro:property name="wheel_radius"     value="0.065"/>
  <xacro:property name="wheel_width"      value="0.045"/>
  <xacro:property name="wheel_separation" value="0.45"/>
  <xacro:property name="wheel_diameter"   value="${2 * wheel_radius}"/>

  <!-- Spawn height: |wheel_joint_z| + wheel_radius + 1 cm clearance -->
  <xacro:property name="max_wheel_z" value="0.04"/>
  <xacro:property name="spawn_z"     value="${max_wheel_z + wheel_radius + 0.01}"/>

  <!-- Casters -->
  <xacro:property name="caster_mass"   value="0.108"/>
  <xacro:property name="caster_radius" value="0.0325"/>

  <!-- ============================================================
       Inertia macros
       ============================================================ -->

  <xacro:macro name="box_inertia" params="m l w h xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(1/12.0) * m * (h*h + l*l)}" ixy="0" ixz="0"
               iyy="${(1/12.0) * m * (w*w + l*l)}" iyz="0"
               izz="${(1/12.0) * m * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(1/12.0) * m * (3*r*r + h*h)}" ixy="0" ixz="0"
               iyy="${(1/12.0) * m * (3*r*r + h*h)}" iyz="0"
               izz="${0.5 * m * r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(2/5.0) * m * r*r}" ixy="0" ixz="0"
               iyy="${(2/5.0) * m * r*r}" iyz="0"
               izz="${(2/5.0) * m * r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Wheel spinning about Y axis -->
  <xacro:macro name="wheel_inertia" params="m r h xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(1/12.0) * m * (3*r*r + h*h)}" ixy="0" ixz="0"
               iyy="${0.5 * m * r*r}"                 iyz="0"
               izz="${(1/12.0) * m * (3*r*r + h*h)}"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================
       Links
       ============================================================ -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.105" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <xacro:box_inertia m="10.0" l="0.42" w="0.2" h="0.2"
                       xyz="0 0 0.1" rpy="0 0 0"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://food_del_robot_full_description/meshes/base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_len} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <link name="right_wheel_link">
    <xacro:wheel_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"
                         xyz="0 0 0" rpy="0 0 0"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://food_del_robot_full_description/meshes/right_wheel_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_right_wheel_joint" type="continuous">
    <origin xyz="0 -0.225 -0.04" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_wheel_link">
    <xacro:wheel_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"
                         xyz="0 0 0" rpy="0 0 0"/>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://food_del_robot_full_description/meshes/left_wheel_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_left_wheel_joint" type="continuous">
    <origin xyz="0 0.225 -0.04" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ============================================================
       LiDAR — RPLidar A1
       360° scan, 0.15m–12m, 1° resolution = 360 samples
       ============================================================ -->
  <link name="lidar_link">
    <inertial>
      <origin xyz="0.010632 -0.0016703 -0.018432" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1.9581E-05" ixy="-1.0393E-07" ixz="-4.2839E-07"
               iyy="2.4125E-05" iyz="9.4269E-09"
               izz="4.1418E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://food_del_robot_full_description/meshes/lidar_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.1 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_lidar_joint" type="fixed">
    <origin xyz="0.17965 0.0011689 0.14817" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- ============================================================
       Camera — Intel RealSense D435i
       Depth FOV: 87°x58°, Range: 0.3m–3m
       RGB: 1920x1080 @ 30fps
       ============================================================ -->
  <link name="camera_link">
    <inertial>
      <origin xyz="-0.016393 -0.014932 -1.9236E-05" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="4.7928E-05" ixy="-1.6932E-06" ixz="-2.8381E-08"
               iyy="1.5244E-05" iyz="2.4938E-09"
               izz="5.159E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://food_del_robot_full_description/meshes/camera_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_camera_joint" type="fixed">
    <origin xyz="0.28915 0.017531 0.091186" rpy="0 -0.7854 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- Depth optical frame — referenced by Gazebo camera plugin -->
  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
  </joint>

  <!-- IMU link -->
  <link name="imu_link">
    <inertial>
      <origin xyz="-1.2594E-05 -1.1909E-07 -0.0069553" rpy="0 0 0"/>
      <mass value="0.013048"/>
      <inertia ixx="2.9945E-06" ixy="4.6016E-12" ixz="2.1648E-08"
               iyy="1.9851E-06" iyz="2.4504E-14"
               izz="4.5735E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://food_del_robot_full_description/meshes/imu_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_imu_joint" type="fixed">
    <origin xyz="4.5433E-05 3.0734E-05 0.011601" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- Caster wheels — Z recalculated for new base_link origin (spawn_z = 0.1155 m) -->
  <link name="caster1_link">
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}" xyz="0 0 0" rpy="0 0 0"/>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://food_del_robot_full_description/meshes/caster1_link.STL"/></geometry>
      <material name=""><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
  </link>
  <joint name="c1_b_joint" type="fixed">
    <origin xyz="-0.1845 -0.1560 -0.075" rpy="0 0 0"/>
    <parent link="base_link"/><child link="caster1_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <link name="caster2_link">
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}" xyz="0 0 0" rpy="0 0 0"/>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://food_del_robot_full_description/meshes/caster2_link.STL"/></geometry>
      <material name=""><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
  </link>
  <joint name="c2_b_joint" type="fixed">
    <origin xyz="-0.1845 0.1830 -0.075" rpy="0 0 0"/>
    <parent link="base_link"/><child link="caster2_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <link name="caster3_link">
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}" xyz="0 0 0" rpy="0 0 0"/>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://food_del_robot_full_description/meshes/caster3_link.STL"/></geometry>
      <material name=""><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
  </link>
  <joint name="c3_b_joint" type="fixed">
    <origin xyz="0.1845 -0.1560 -0.075" rpy="0 0 0"/>
    <parent link="base_link"/><child link="caster3_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <link name="caster4_link">
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}" xyz="0 0 0" rpy="0 0 0"/>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://food_del_robot_full_description/meshes/caster4_link.STL"/></geometry>
      <material name=""><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
  </link>
  <joint name="c4_b_joint" type="fixed">
    <origin xyz="0.1845 0.1830 -0.075" rpy="0 0 0"/>
    <parent link="base_link"/><child link="caster4_link"/>
    <axis xyz="0 0 0"/>
  </joint>

  <!-- ============================================================
       Gazebo plugins — only loaded when use_sim:=true
       ============================================================ -->
  <xacro:if value="$(arg use_sim)">

    <!-- Wheel friction -->
    <gazebo reference="right_wheel_link">
      <mu1>1.0</mu1><mu2>1.0</mu2>
      <kp>1000000.0</kp><kd>10.0</kd>
      <fdir1>1 0 0</fdir1>
      <minDepth>0.001</minDepth><maxVel>0.1</maxVel>
    </gazebo>
    <gazebo reference="left_wheel_link">
      <mu1>1.0</mu1><mu2>1.0</mu2>
      <kp>1000000.0</kp><kd>10.0</kd>
      <fdir1>1 0 0</fdir1>
      <minDepth>0.001</minDepth><maxVel>0.1</maxVel>
    </gazebo>

    <!-- Caster friction -->
    <gazebo reference="caster1_link">
      <mu1>0.01</mu1><mu2>0.01</mu2><kp>100000.0</kp><kd>100.0</kd>
    </gazebo>
    <gazebo reference="caster2_link">
      <mu1>0.01</mu1><mu2>0.01</mu2><kp>100000.0</kp><kd>100.0</kd>
    </gazebo>
    <gazebo reference="caster3_link">
      <mu1>0.01</mu1><mu2>0.01</mu2><kp>100000.0</kp><kd>100.0</kd>
    </gazebo>
    <gazebo reference="caster4_link">
      <mu1>0.01</mu1><mu2>0.01</mu2><kp>100000.0</kp><kd>100.0</kd>
    </gazebo>

    <!-- Differential drive plugin -->
    <gazebo>
      <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive_controller">
        <update_rate>50</update_rate>
        <left_joint>base_left_wheel_joint</left_joint>
        <right_joint>base_right_wheel_joint</right_joint>
        <wheel_separation>${wheel_separation}</wheel_separation>
        <wheel_diameter>${wheel_diameter}</wheel_diameter>
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>0.8</max_wheel_acceleration>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
        <odometry_topic>odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
      </plugin>
    </gazebo>

    <!-- =====================================================
         RPLidar A1 — Ray sensor
         360°, 0.15m–12m, 1° resolution = 360 samples
         Scan rate: 5.5Hz
         ===================================================== -->
    <xacro:if value="$(arg use_lidar)">
    <gazebo reference="lidar_link">
      <sensor name="lidar" type="ray">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <update_rate>5.5</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.15</min>
            <max>12.0</max>
            <resolution>0.002</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="lidar" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <topic>scan</topic>
          <frame_name>lidar_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>
    </xacro:if>

    <!-- =====================================================
         Intel RealSense D435i
         RGB:   1920x1080 @ 30fps, FOV 69.4°x42.5°
         Depth: 1280x720  @ 30fps, FOV 87°x58°
         Range: 0.3m – 3m (ideal), absolute min 0.105m
         ===================================================== -->
    <gazebo reference="camera_link">
      <sensor name="d435i_camera" type="depth">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.5184</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.3</near>
            <far>3.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
        </camera>
        <plugin name="d435i_controller" filename="libgazebo_ros_camera.so">
          <frame_name>camera_depth_optical_frame</frame_name>
          <camera_name>camera</camera_name>
          <hack_baseline>0.0</hack_baseline>
          <min_depth>0.3</min_depth>
          <max_depth>3.0</max_depth>
          <ros>
            <namespace>/</namespace>
            <remapping>~/image_raw:=camera/image_raw</remapping>
            <remapping>~/depth_image:=camera/depth/image_raw</remapping>
          </ros>
          <point_cloud_topic>camera/depth/points</point_cloud_topic>
          <point_cloud_cutoff>0.3</point_cloud_cutoff>
          <point_cloud_cutoff_max>3.0</point_cloud_cutoff_max>
        </plugin>
      </sensor>
    </gazebo>

  </xacro:if>

</robot>
