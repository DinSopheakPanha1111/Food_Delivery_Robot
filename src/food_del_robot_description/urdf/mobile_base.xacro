<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Defining some variables -->
    <xacro:property name="base_length" value="0.6"/>
    <xacro:property name="base_width" value="0.4"/>
    <xacro:property name="base_height" value="0.2"/>
    <xacro:property name="wheel_radius" value="0.1"/>
    <xacro:property name="wheel_width" value="0.05"/>
    <xacro:property name="caster_wheel_radius" value="${wheel_radius / 2.0}"/>
    <!-- ======================= -->
    <xacro:property name="caster_wheel_support_radius" value="0.04"/>
    <xacro:property name="caster_wheel_support_length" value="${caster_wheel_radius * 0.2}"/>
    <xacro:property name="caster_wheel_real_radius" value="${caster_wheel_radius * 0.8}"/>
    <xacro:property name="caster_wheel_width" value="${wheel_width * 0.5}"/>
    <!-- ============= Defining the links of the robot ============== -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/> <!-- origin of the link -->
            <!-- r is roll, p is pitch, y is yaw -->
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/> <!-- origin of the link -->
        </collision>
        <xacro:box_inertia m="5.0" l="${base_length}" w="${base_width}" h="${base_height}" 
                           xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
    </link>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/> <!-- pi is the constant already exist in xacro -->
                <material name="gray"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" h="${wheel_width}" 
                                    xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="right"/>
    <xacro:wheel_link prefix="left"/>

    <link name="caster_wheel_link_support">
        <visual>
            <geometry>
                <cylinder radius="${caster_wheel_support_radius}" length="${caster_wheel_support_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/> <!-- origin of the link -->
            <material name="gray"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${caster_wheel_support_radius}" length="${caster_wheel_support_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/> <!-- origin of the link -->
        </collision>
        <xacro:cylinder_inertia m="0.05" r="${caster_wheel_support_radius}" h="${caster_wheel_support_length}" 
                              xyz="0 0 0" rpy="0 0 0"/>
    </link>

    <link name="caster_wheel_real_link">
        <visual>
            <geometry>
                <cylinder radius="${caster_wheel_real_radius}" length="${caster_wheel_width}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/> <!-- origin of the link -->
            <material name="gray"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${caster_wheel_real_radius}" length="${caster_wheel_width}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <xacro:cylinder_inertia m="0.1" r="${caster_wheel_real_radius}" h="${caster_wheel_width}" 
                              xyz="0 0 0" rpy="0 0 0"/>
    </link>

    

    <link name="base_footprint" /> <!-- This link represents the footprint of the robot on the ground it is empty-->
    <!-- ============================================================= -->


    <!-- ============= Defining the joints of the robot ============== -->
    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="${-base_length / 4.0} ${-base_width / 2.0 - wheel_width / 2.0} 0" rpy="0 0 0"/> <!-- origin of the joint -->
        <axis xyz="0 1 0"/> <!-- axis of rotation --> 
    </joint>   

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="${-base_length / 4.0} ${base_width / 2.0 + wheel_width / 2.0} 0" rpy="0 0 0"/> <!-- origin of the joint -->
        <axis xyz="0 1 0"/> <!-- axis of rotation --> 
    </joint>

    <joint name="base_caster_wheel_support_joint" type="continuous">
        <parent link="base_link"/>
        <child link="caster_wheel_link_support"/>
        <origin xyz="${base_length / 3.0} 0 ${-caster_wheel_support_length / 2.0}" rpy="0 0 0"/> <!-- origin of the joint -->
        <axis xyz="0 0 1"/> <!-- axis of rotation -->
    </joint>

    <joint name="base_caster_wheel_real_joint" type="continuous">
        <parent link="caster_wheel_link_support"/>
        <child link="caster_wheel_real_link"/>
        <origin xyz="0 0 ${-caster_wheel_support_length / 2.0 - caster_wheel_real_radius}" rpy="1.57 1.57 0"/> <!-- origin of the joint -->
        <axis xyz="0 0 1"/> <!-- axis of rotation -->
    </joint>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/> <!-- origin of base_footprint_link -->
    </joint>

    <!-- ============================================================== -->

</robot>