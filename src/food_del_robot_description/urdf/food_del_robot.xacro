<?xml version="1.0"?>
<robot name="food_del_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Xacro parameters -->
    <xacro:property name="base_length" value="0.48"/>
    <xacro:property name="base_height" value="0.2"/>
    <xacro:property name="base_width" value="0.48"/>
    <xacro:property name="base_height_from_ground" value="0.01"/>
    <xacro:property name="base_to_wheel_center" value="0.0555"/>
    <xacro:property name="distance_between_two_wheels" value="0.45"/> 
    <xacro:property name="wheel_radius" value="0.065"/>
    <xacro:property name="wheel_length" value="0.04"/>
    <xacro:property name="rotate_90" value="1.57"/>
    <xacro:property name ="lidar_length" value = "0.043"/>
    <xacro:property name ="lidar_radius" value = "0.035"/>
    <xacro:property name ="lidar_shift_from_center" value = "0.172"/>
    <xacro:property name="imu_length" value="0.031"/>
    <xacro:property name="imu_height" value="0.016"/>
    <xacro:property name="imu_width" value="0.025"/>
    <xacro:property name="imu_height_from_ground" value="0.110"/>
    <xacro:property name="camera_length" value="0.025"/>
    <xacro:property name="camera_height" value="0.025"/>
    <xacro:property name="camera_width" value="0.09"/>
    <xacro:property name="camera_height_from_ground" value="0.150"/>



    <!-- Wheel macro -->
    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <!-- Rotate cylinder to roll correctly along Y axis -->
                <origin xyz="0.0 0.0 0.0" rpy="${rotate_90} 0.0 0.0"/>
                <material name="red"/>
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            </collision>
            <xacro:cylinder_inertia 
                m="1.0" 
                r="${wheel_radius}" 
                l="${wheel_length}" 
                o_xyz="0.0 0.0 0.0" 
                o_rpy="0.0 ${rotate_90} 0.0"/>
        </link>
    </xacro:macro>

    <!-- Instantiate wheels -->
    <xacro:wheel_link prefix="right"/>
    <xacro:wheel_link prefix="left"/>

    <!-- Base footprint -->
    <link name="base_footprint"/>

    <!-- Base links -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${base_height / 2.0}" rpy="0.0 0.0 0.0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${base_height / 2.0}" rpy="0.0 0.0 0.0"/>
        </collision>
        <xacro:box_inertia 
            m="5.0" 
            x="${base_length}" 
            y="${base_width}" 
            z="${base_height}" 
            o_xyz="0.0 0.0 ${base_height / 2.0}" 
            o_rpy="0.0 0.0 0.0"/>
    </link>

    <!-- Base scan link -->
    <link name="laser_link">
        <visual>
            <geometry>
                <cylinder radius="${lidar_radius}" length="${lidar_length}"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${lidar_radius}" length="${lidar_length}"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </collision>
        <xacro:cylinder_inertia 
            m="0.2" 
            r="${lidar_radius}" 
            l="${lidar_length}" 
            o_xyz="0.0 0.0 0.0" 
            o_rpy="0.0 0.0 0.0"/>
    </link>

    <!-- IMU link -->
    <link name="imu_link">
        <visual>
            <geometry>
                <box size="${imu_length} ${imu_width} ${imu_height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${imu_height / 2.0}" rpy="0.0 0.0 0.0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${imu_length} ${imu_width} ${imu_height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${imu_height / 2.0}" rpy="0.0 0.0 0.0"/>
        </collision>
        <xacro:box_inertia 
            m="5.0" 
            x="${imu_length}" 
            y="${imu_width}" 
            z="${imu_height}" 
            o_xyz="0.0 0.0 ${imu_height / 2.0}" 
            o_rpy="0.0 0.0 0.0"/>
    </link>

    <!-- Camera link -->
    <link name="camera_link">
        <visual>
            <geometry>
                <box size="${camera_length} ${camera_width} ${camera_height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${camera_height / 2.0}" rpy="0.0 0.0 0.0"/>
            <material name="pink"/>
        </visual>
        <collision>
            <geometry>
                <box size="${camera_length} ${camera_width} ${camera_height}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${camera_height / 2.0}" rpy="0.0 0.0 0.0"/>
        </collision>
        <xacro:box_inertia 
            m="0.5" 
            x="${camera_length}" 
            y="${camera_width}" 
            z="${camera_height}" 
            o_xyz="0.0 0.0 ${camera_height / 2.0}" 
            o_rpy="0.0 0.0 0.0"/>
    </link>

    <!-- base footprint - base link joint -->
    <joint name="base_footprint_base_link_joint" type="fixed">
        <origin xyz="0.0 0.0 ${base_height_from_ground}" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <!-- base link - right wheel link joint -->
    <joint name="base_right_wheel_joint" type="continuous">
        <origin xyz="0.0 ${distance_between_two_wheels/2} ${base_to_wheel_center}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <!-- base link - left wheel link joint -->
    <joint name="base_left_wheel_joint" type="continuous">
        <origin xyz="0.0 ${-distance_between_two_wheels/2} ${base_to_wheel_center}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <!-- base link - base scan link joint -->
    <joint name="laser_base_link_joint" type="fixed">
        <origin xyz="${lidar_shift_from_center} 0.0 ${base_height + (lidar_length/2)}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="laser_link"/>
    </joint>

    <!-- base link - imu link joint -->
    <joint name="base_imu_joint" type="fixed">
        <origin xyz="0.0 0.0 ${imu_height_from_ground}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="imu_link"/>
    </joint>

    <!-- base link - camera link joint -->
    <joint name="base_camera_joint" type="fixed">
        <origin xyz="${base_length/2.0} 0.0 ${camera_height_from_ground}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="camera_link"/>
    </joint>

</robot>
