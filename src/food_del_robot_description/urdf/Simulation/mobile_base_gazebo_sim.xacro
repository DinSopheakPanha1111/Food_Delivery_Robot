<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <gazebo reference="base_link">
        <material>Gazebo/Blue</material>
    </gazebo>

    <gazebo reference="base_left_wheel_link">
        <material>Gazebo/Gray</material>
        <mu1>5.0</mu1>
        <mu2>5.0</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>0.1</maxVel>
        <slip1>0.0</slip1>
        <slip2>0.0</slip2>
    </gazebo>

    <gazebo reference="base_right_wheel_link">
        <material>Gazebo/Gray</material>
        <mu1>5.0</mu1>
        <mu2>5.0</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>0.1</maxVel>
        <slip1>0.0</slip1>
        <slip2>0.0</slip2>
    </gazebo>

    <gazebo reference="caster_wheel_link_support">
        <material>Gazebo/Gray</material>
    </gazebo>

    <gazebo reference="caster_wheel_real_link">
        <mu1>0.0</mu1>   <!-- Should be near-zero for free-rolling -->
        <mu2>0.0</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.001</minDepth>
        <maxVel>1.0</maxVel>   <!-- Also increase this -->
        <slip1>1.0</slip1>     <!-- Allow slip -->
        <slip2>1.0</slip2>
    </gazebo>

    <gazebo reference="laser_link">
        <material>Gazebo/Red</material>
        <sensor name="laser" type="ray">
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>8</update_rate>
            <ray> 
                <scan>
                    <horizontal>
                        <samples>1083</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.1241390705108643</min_angle>
                        <max_angle>3.1415927410125732</max_angle> 
                    </horizontal>
                </scan>
                <range>
                    <min>0.1</min>
                    <max>12</max>
                </range>
            </ray>
            <plugin name="lidar" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <remapping>~/out:=scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <topic>scan</topic>
                <frame_name>laser_link</frame_name> 
                <transport>ros</transport>
            </plugin>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive_controller">
            <update_rate>50</update_rate>
            <left_joint>base_left_wheel_joint</left_joint>
            <right_joint>base_right_wheel_joint</right_joint>
            <wheel_separation>0.45</wheel_separation>
            <wheel_diameter>0.2</wheel_diameter>
            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
            <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
        </plugin>
    </gazebo>
</robot>