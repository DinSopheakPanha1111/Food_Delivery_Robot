<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Defining some variables -->
    <xacro:property name="base_length" value="0.6"/>
    <xacro:property name="base_width" value="0.4"/>
    <xacro:property name="base_height" value="0.2"/>
    <xacro:property name="wheel_radius" value="0.1"/>
    <xacro:property name="wheel_width" value="0.05"/>
    <xacro:property name="caster_wheel_radius" value="${wheel_radius / 2.0}"/>

    <!-- FIXED -->
    <xacro:property name="caster_wheel_support_radius" value="0.04"/>
    <xacro:property name="caster_wheel_real_radius" value="${caster_wheel_radius * 0.8}"/>
    <xacro:property name="caster_wheel_support_length" value="${wheel_radius - 2.0 * caster_wheel_real_radius}"/>
    <xacro:property name="caster_wheel_width" value="${wheel_width * 0.5}"/>
    <!-- ============= Defining the links of the robot ============== -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
        </collision>
        <!-- FIX: l→x, w→y, h→z; xyz/rpy renamed to o_xyz/o_rpy -->
        <xacro:box_inertia m="5.0" x="${base_length}" y="${base_width}" z="${base_height}"
                           o_xyz="0 0 ${base_height / 2.0}" o_rpy="0 0 0"/>
    </link>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
                <material name="gray"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
            </collision>
            <!-- FIX: h→l; xyz/rpy renamed to o_xyz/o_rpy -->
            <xacro:cylinder_inertia m="1.0" r="${wheel_radius}" l="${wheel_width}"
                                    o_xyz="0 0 0" o_rpy="${pi / 2.0} 0 0"/>
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="right"/>
    <xacro:wheel_link prefix="left"/>

    <link name="caster_wheel_link_support">
        <visual>
            <geometry>
                <cylinder radius="${caster_wheel_support_radius}" length="${caster_wheel_support_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="gray"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${caster_wheel_support_radius}" length="${caster_wheel_support_length}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <!-- FIX: h→l; xyz/rpy renamed to o_xyz/o_rpy -->
        <xacro:cylinder_inertia m="0.05" r="${caster_wheel_support_radius}" l="${caster_wheel_support_length}"
                                o_xyz="0 0 0" o_rpy="0 0 0"/>
    </link>

    <link name="caster_wheel_real_link">
        <visual>
            <geometry>
                <cylinder radius="${caster_wheel_real_radius}" length="${caster_wheel_width}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="gray"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${caster_wheel_real_radius}" length="${caster_wheel_width}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <!-- FIX: h→l; xyz/rpy renamed to o_xyz/o_rpy -->
        <xacro:cylinder_inertia m="0.1" r="${caster_wheel_real_radius}" l="${caster_wheel_width}"
                                o_xyz="0 0 0" o_rpy="0 0 0"/>
    </link>

    <link name="base_footprint" />
    <!-- ============================================================= -->


    <!-- ============= Defining the joints of the robot ============== -->
    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="${-base_length / 4.0} ${base_width / 2.0 + wheel_width / 2.0} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="${-base_length / 4.0} ${-base_width / 2.0 - wheel_width / 2.0} 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="base_caster_wheel_support_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel_link_support"/>
        <origin xyz="${base_length / 3.0} 0 ${-caster_wheel_support_length / 2.0}" rpy="0 0 0"/>
    </joint>

    <joint name="base_caster_wheel_real_joint" type="fixed">
        <parent link="caster_wheel_link_support"/>
        <child link="caster_wheel_real_link"/>
        <origin xyz="0 0 ${-caster_wheel_support_length / 2.0 - caster_wheel_real_radius}" rpy="1.57 1.57 0"/>
    </joint>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>
    <!-- ============================================================== -->

</robot>